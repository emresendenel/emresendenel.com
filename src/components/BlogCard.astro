---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="block group">
  <div class="card p-6">
    <div class="flex items-start justify-between gap-4 mb-3">
      <span class="text-meta text-text-secondary uppercase tracking-wider shrink-0 pt-1">
        {formattedDate}
      </span>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 justify-end">
          {tags.map((tag) => (
            <span class="tag-chip text-[10px]">{tag}</span>
          ))}
        </div>
      )}
    </div>
    <h3 class="text-h3 font-semibold text-text-primary group-hover:text-accent transition-colors duration-200 mb-2">
      {title}
    </h3>
    <p class="text-[15px] text-text-secondary leading-relaxed">
      {description}
    </p>
  </div>
</a>
