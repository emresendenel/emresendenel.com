---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Rough reading time estimate
const wordsPerMinute = 200;
---

<a
  href={`/blog/${slug}`}
  class="group block py-6 border-b border-border last:border-b-0 transition-colors hover:bg-tag/30 -mx-4 px-4 rounded-lg"
  id={`blog-post-${slug}`}
>
  <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-6">
    <!-- Date -->
    <time
      datetime={pubDate.toISOString()}
      class="text-meta text-text-secondary font-body shrink-0 sm:w-28 sm:pt-1"
    >
      {formattedDate}
    </time>

    <!-- Content -->
    <div class="flex-1">
      <h3 class="font-body text-[18px] font-semibold text-text-primary group-hover:text-accent transition-colors mb-1.5 leading-snug">
        {title}
      </h3>
      <p class="text-[15px] text-text-secondary leading-relaxed mb-3">
        {description}
      </p>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="tag-chip text-[12px]">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Arrow -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-text-secondary/40 group-hover:text-accent group-hover:translate-x-1 transition-all shrink-0 mt-1 hidden sm:block"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </div>
</a>
