---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-border-light"
  style="background: rgba(255,255,255,0.92); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
>
  <div class="container-content flex items-center justify-between h-[72px]">
    <!-- Logo -->
    <a href="/" class="text-[20px] font-bold text-text-primary hover:text-accent transition-colors duration-200">
      Emre Sendenel
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-2" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        const isContact = href === '/contact';
        return isContact ? (
          <a
            href={href}
            class="ml-2 px-5 py-2 bg-accent text-white text-nav font-semibold rounded-btn
                   hover:bg-accent-hover hover:-translate-y-0.5
                   transition-all duration-200 shadow-card"
          >
            {label}
          </a>
        ) : isActive ? (
          <a href={href} class="nav-link-active">{label}</a>
        ) : (
          <a href={href} class="nav-link px-3 py-1.5">{label}</a>
        );
      })}
    </nav>

    <!-- Mobile Hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-[5px] w-8 h-8 items-center justify-center relative z-50"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="menu-line w-5 h-[2px] bg-text-primary transition-all duration-200 origin-center rounded-full"></span>
      <span class="menu-line w-5 h-[2px] bg-text-primary transition-all duration-200 origin-center rounded-full"></span>
      <span class="menu-line w-5 h-[2px] bg-text-primary transition-all duration-200 origin-center rounded-full"></span>
    </button>
  </div>
</header>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="fixed inset-x-0 top-[72px] z-40 bg-white border-b border-border shadow-card
         max-h-0 overflow-hidden transition-all duration-300"
>
  <nav class="flex flex-col p-6 gap-1" aria-label="Mobile navigation">
    {navLinks.map(({ href, label }) => {
      const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
      const isContact = href === '/contact';
      return isContact ? (
        <a
          href={href}
          class="mt-2 px-5 py-3 bg-accent text-white text-center font-semibold rounded-btn
                 hover:bg-accent-hover transition-all duration-200"
        >
          {label}
        </a>
      ) : (
        <a
          href={href}
          class={`px-4 py-3 rounded-btn text-[16px] font-medium transition-colors duration-200
                  ${isActive ? 'bg-accent text-white' : 'text-text-primary hover:bg-tag-bg hover:text-accent'}`}
        >
          {label}
        </a>
      );
    })}
  </nav>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = toggle?.querySelectorAll('.menu-line');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));

    if (open) {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
      if (lines) {
        lines[0].style.transform = 'rotate(45deg) translate(2px, 5px)';
        lines[1].style.opacity = '0';
        lines[2].style.transform = 'rotate(-45deg) translate(2px, -5px)';
      }
    } else {
      menu!.style.maxHeight = '0';
      if (lines) {
        lines[0].style.transform = '';
        lines[1].style.opacity = '1';
        lines[2].style.transform = '';
      }
    }
  });
</script>
