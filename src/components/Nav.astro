---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  return current.startsWith(href);
}
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-border/60"
>
  <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20 flex items-center justify-between h-[72px]">
    <!-- Logo -->
    <a
      href="/"
      class="font-display text-[22px] font-bold text-text-primary hover:text-accent transition-colors tracking-tight"
      aria-label="Emre Sendenel - Home"
    >
      Emre Sendenel
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'font-body text-[15px] font-medium transition-colors relative py-1',
              isActive(href, currentPath)
                ? 'text-accent after:absolute after:bottom-0 after:left-0 after:right-0 after:h-[2px] after:bg-accent after:rounded-full'
                : 'text-text-secondary hover:text-text-primary',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden flex flex-col items-center justify-center w-10 h-10 gap-1.5 rounded-lg hover:bg-tag transition-colors"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <span id="hamburger-top" class="block w-5 h-[2px] bg-text-primary transition-all duration-300 origin-center"></span>
      <span id="hamburger-mid" class="block w-5 h-[2px] bg-text-primary transition-all duration-300"></span>
      <span id="hamburger-bot" class="block w-5 h-[2px] bg-text-primary transition-all duration-300 origin-center"></span>
    </button>
  </div>

  <!-- Mobile Overlay -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 top-[72px] bg-white/98 backdrop-blur-lg z-40 opacity-0 pointer-events-none transition-opacity duration-300"
  >
    <ul class="flex flex-col items-center justify-center h-full gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'font-display text-[28px] font-semibold transition-colors',
              isActive(href, currentPath) ? 'text-accent' : 'text-text-primary hover:text-accent',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<!-- Spacer for fixed nav -->
<div class="h-[72px]"></div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const top = document.getElementById('hamburger-top');
  const mid = document.getElementById('hamburger-mid');
  const bot = document.getElementById('hamburger-bot');
  let isOpen = false;

  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    toggle.setAttribute('aria-expanded', String(isOpen));

    if (isOpen) {
      menu?.classList.remove('opacity-0', 'pointer-events-none');
      menu?.classList.add('opacity-100', 'pointer-events-auto');
      top?.classList.add('rotate-45', 'translate-y-[5px]');
      mid?.classList.add('opacity-0');
      bot?.classList.add('-rotate-45', '-translate-y-[5px]');
      document.body.style.overflow = 'hidden';
    } else {
      menu?.classList.add('opacity-0', 'pointer-events-none');
      menu?.classList.remove('opacity-100', 'pointer-events-auto');
      top?.classList.remove('rotate-45', 'translate-y-[5px]');
      mid?.classList.remove('opacity-0');
      bot?.classList.remove('-rotate-45', '-translate-y-[5px]');
      document.body.style.overflow = '';
    }
  });
</script>
