---
interface Props {
  title: string;
  description: string;
  tags: string[];
  role?: string;
  period?: string;
  status?: string;
  gradient?: string;
}

const {
  title,
  description,
  tags,
  role,
  period,
  status,
  gradient = 'from-accent/10 to-accent/5',
} = Astro.props;
---

<div class="card group cursor-default">
  <!-- Image Placeholder -->
  <div class={`w-full h-48 rounded-lg mb-5 bg-gradient-to-br ${gradient} flex items-center justify-center`}>
    <span class="text-accent/30 font-display text-[32px] font-bold select-none">
      {title.split(' ').map(w => w[0]).join('').slice(0, 3)}
    </span>
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.map((tag) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>

  <!-- Title -->
  <h3 class="font-body text-h3 text-text-primary mb-1">{title}</h3>

  <!-- Role and Period -->
  {(role || period) && (
    <div class="mb-3 text-[14px] font-medium text-text-secondary flex flex-wrap gap-x-2 items-center">
      {role && <span class="text-text-primary">{role}</span>}
      {role && period && <span class="text-border">•</span>}
      {period && <span>{period}</span>}
    </div>
  )}

  <!-- Description -->
  <p class="text-[15px] text-text-secondary leading-relaxed mb-4">{description}</p>

  <!-- Status & Arrow -->
  <div class="flex items-center justify-between">
    {status && (
      <span class="inline-flex items-center gap-1.5 text-meta text-text-secondary">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
        {status}
      </span>
    )}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-text-secondary group-hover:text-accent group-hover:translate-x-1 transition-all ml-auto"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </div>
</div>
