---
interface TimelineEntry {
  role: string;
  company: string;
  period: string;
  description: string;
  isCurrent?: boolean;
}

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;
---

<div class="relative pl-10">
  <!-- Vertical line -->
  <div class="absolute left-[9px] top-3 bottom-3 w-[2px] bg-accent/20 rounded-full"></div>

  {entries.map((entry) => (
    <div class="relative pb-10 last:pb-0">
      <!-- Dot -->
      <div
        class={`absolute left-[-33px] top-[8px] w-[20px] h-[20px] rounded-full border-[3px]
                ${entry.isCurrent
                  ? 'bg-accent border-accent shadow-[0_0_10px_rgba(124,58,237,0.3)]'
                  : 'bg-white border-accent/30 hover:border-accent transition-colors duration-200'
                }`}
      ></div>

      <!-- Card -->
      <div class="card p-5">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div>
            <h3 class="text-[17px] font-semibold text-text-primary mb-0.5">
              {entry.role}
            </h3>
            <p class="text-[14px] text-accent font-semibold">
              {entry.company}
            </p>
          </div>
          {entry.isCurrent && (
            <span class="status-current text-[11px]">Current</span>
          )}
        </div>
        <p class="text-meta text-text-secondary mt-1 mb-2 uppercase tracking-wider">
          {entry.period}
        </p>
        <p class="text-[15px] text-text-secondary leading-relaxed">
          {entry.description}
        </p>
      </div>
    </div>
  ))}
</div>
