---
interface TimelineEntry {
  role: string;
  company: string;
  period: string;
  description?: string;
  isCurrent?: boolean;
}

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;
---

<div class="relative">
  <!-- Vertical line -->
  <div class="absolute left-[11px] top-4 bottom-4 w-[2px] bg-border"></div>

  <div class="space-y-10">
    {entries.map((entry) => (
      <div class="relative pl-10 group">
        <!-- Dot -->
        <div
          class:list={[
            'absolute left-0 top-[6px] w-6 h-6 rounded-full border-2 flex items-center justify-center transition-colors',
            entry.isCurrent
              ? 'border-accent bg-accent'
              : 'border-border bg-surface group-hover:border-accent/50',
          ]}
        >
          {entry.isCurrent && (
            <div class="w-2 h-2 rounded-full bg-white"></div>
          )}
        </div>

        <!-- Content -->
        <div>
          <h3 class="font-body text-[17px] font-semibold text-text-primary leading-snug">
            {entry.role}
          </h3>
          <p class="text-meta text-text-secondary mt-1">
            <span>{entry.company}</span>
            <span class="mx-1.5">·</span>
            <span class:list={[entry.isCurrent && 'text-accent font-medium']}>
              {entry.period}
            </span>
          </p>
          {entry.description && (
            <p class="text-[15px] text-text-secondary mt-2 leading-relaxed">
              {entry.description}
            </p>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
