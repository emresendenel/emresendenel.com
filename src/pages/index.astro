---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import ProjectCard from '../components/ProjectCard.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Emre Sendenel",
  "jobTitle": "Project Manager",
  "url": "https://emresendenel.com",
  "email": "emresendenel@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Düsseldorf",
    "addressCountry": "DE"
  },
  "sameAs": ["https://www.linkedin.com/in/emresendenel"]
};

const timelineEntries = [
  {
    role: 'Project Manager',
    company: 'CONET Services GmbH',
    period: 'Apr 2022 – Present',
    description: 'IT consulting and project delivery across public sector clients in Germany.',
    isCurrent: true,
  },
  {
    role: 'Project Manager — Public Sector',
    company: 'Confidential Client',
    period: 'Jun 2022 – Dec 2024',
    description: 'PMO and project management for large-scale government IT infrastructure in Bonn.',
  },
  {
    role: 'Project Manager — IT Systems',
    company: 'Confidential Client',
    period: 'Jun 2023 – Mar 2024',
    description: 'IT infrastructure operations and system commissioning for a public sector client.',
  },
  {
    role: 'Product Manager / Project Manager',
    company: 'Doğuş Automotive (VW Turkey)',
    period: 'Feb 2010 – Nov 2017',
    description: "Product ownership and project management for VW Turkey's digital and ERP initiatives.",
  },
];

const skills = [
  'PMP Certified', 'ITIL® Foundation V4', 'PSM I', 'Agile', 'Scrum',
  'Jira', 'MS Project', 'Power BI', 'Stakeholder Management',
  'Budget Planning', 'Risk Management', 'Cross-functional Teams',
  'Turkish (Native)', 'English (C1)', 'German (B2)',
];
---

<BaseLayout
  title="Emre Sendenel | Project Manager · PMP Certified"
  description="Emre Sendenel is a PMP-certified Project Manager based in Düsseldorf, Germany. 15+ years delivering complex projects across technology, automotive, and public sector."
  jsonLd={jsonLd}
>
  <!-- ==================== HERO ==================== -->
  <section id="hero" class="hero-gradient min-h-[90vh] lg:min-h-screen flex items-center pt-6 md:pt-12 pb-section-sm md:pb-section">
    <div class="container-content w-full">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Left Column -->
        <div class="flex-1 lg:max-w-[50%]">
          <p class="text-meta text-accent uppercase tracking-wider mb-4 animate-fade-up stagger-1">
            PMP Certified Project Manager
          </p>
          <h1 class="text-[40px] md:text-hero font-extrabold text-text-primary mb-6 tracking-tight leading-tight animate-fade-up stagger-2">
            Hello, I'm<br />Emre Sendenel
          </h1>
          <p class="text-body text-text-secondary max-w-[500px] mb-8 animate-fade-up stagger-3">
            Delivering complex projects across IT consulting, automotive, and public sector for 15+ years. I turn strategy into execution — on time, on budget, across borders.
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap items-center gap-5 mb-10 animate-fade-up stagger-4">
            <a href="/contact" class="btn-primary">Get in Touch</a>
            <a href="/projects" class="btn-secondary">
              View Projects
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>

          <!-- Stats Row -->
          <div class="grid grid-cols-3 gap-3 animate-fade-up stagger-5">
            <div class="stat-block">
              <div class="stat-number">15 Y.</div>
              <div class="stat-label">Experience</div>
            </div>
            <div class="stat-block">
              <div class="stat-number">6+</div>
              <div class="stat-label">Projects Delivered</div>
            </div>
            <div class="stat-block">
              <div class="stat-number">3</div>
              <div class="stat-label">Countries</div>
            </div>
          </div>
        </div>

        <!-- Right Column — Photo Card -->
        <div class="shrink-0 animate-fade-up stagger-3">
          <div class="card-gradient rounded-photo shadow-photo overflow-hidden">
            <img
              src="/images/hero-photo.png"
              alt="Emre Sendenel — Project Manager"
              loading="eager"
              width="580"
              height="640"
              class="w-[320px] md:w-[480px] lg:w-[580px] h-auto object-cover rounded-photo"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== ABOUT ==================== -->
  <section id="about" class="section-padding bg-white">
    <div class="container-content">
      <div class="reveal">
        <h2 class="text-h2 font-bold text-text-primary mb-12">About Me</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
          <!-- Left — Bio -->
          <div>
            <p class="text-body text-text-secondary mb-6">
              I'm a certified Project Manager (PMP) with a background in Industrial Engineering and a postgraduate degree in Marketing Management.
            </p>
            <p class="text-body text-text-secondary mb-6">
              I've led cross-functional teams at CONET Services GmbH and Doğuş Automotive, managed large-scale public sector IT projects in Germany, and delivered digital products from concept to launch.
            </p>
            <p class="text-body text-text-secondary">
              I work across the full project lifecycle — from requirements and planning to controlling, stakeholder management, and go-live.
            </p>
          </div>

          <!-- Right — Skills -->
          <div>
            <div class="flex flex-wrap gap-2">
              {skills.map((skill) => (
                <span class="tag-chip text-[13px]">{skill}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== EXPERIENCE ==================== -->
  <section id="experience" class="section-padding bg-bg">
    <div class="container-content">
      <div class="reveal">
        <h2 class="text-h2 font-bold text-text-primary mb-12">Experience</h2>
        <div class="max-w-2xl">
          <Timeline entries={timelineEntries} />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SELECTED WORK ==================== -->
  <section id="projects" class="section-padding bg-white">
    <div class="container-content">
      <div class="reveal">
        <h2 class="text-h2 font-bold text-text-primary mb-12">Selected Work</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <ProjectCard
            title="CONET Services GmbH"
            role="Project Manager"
            period="Apr 2022 – Present"
            description="Leading IT projects within the Consulting & Management division. Full project lifecycle ownership: planning, controlling, quality management, stakeholder communication, on/offboarding, and training coordination."
            tags={['IT Consulting', 'PMO', 'Project Management']}
            status="Current"
            statusType="current"
            logo="/images/logos/conet.svg"
            logoAlt="CONET Services logo"
          />
          <ProjectCard
            title="Public Sector — IT Infrastructure (Bonn)"
            role="Project Manager"
            period="Jun 2022 – Dec 2024"
            tags={['Public Sector', 'IT Infrastructure', 'PMO', 'Government']}
            status="Completed"
            statusType="completed"
            description="PMO and project management for a confidential large-scale government IT project in Bonn. Managed data center build-out and full-service operations under a multi-year public sector contract."
            logo="/images/logos/public-sector.png"
            logoAlt="Public sector project"
            isCoverImage={true}
          />
        </div>

        <div class="mt-10 text-center">
          <a href="/projects" class="btn-secondary text-[16px]">
            View All Projects
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CONTACT CTA ==================== -->
  <section id="contact-cta" class="cta-gradient section-padding">
    <div class="container-content">
      <div class="reveal text-center max-w-xl mx-auto">
        <h2 class="text-h2 font-bold text-text-primary mb-4">Let's Work Together</h2>
        <p class="text-body text-text-secondary mb-10">
          Open to project management roles, PMO consulting, and collaborations.
        </p>
        <a href="/contact" class="btn-primary">Send a Message</a>
      </div>
    </div>
  </section>
</BaseLayout>
