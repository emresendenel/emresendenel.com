---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Emre Sendenel"
  description="Get in touch with Emre Sendenel — available for project management roles, PMO consulting, and collaborations."
>
  <section class="section-padding">
    <div class="container-content">
      <!-- Header -->
      <div class="mb-12 animate-fade-up">
        <h1 class="text-[40px] md:text-hero font-extrabold text-text-primary mb-4">
          Get in Touch
        </h1>
        <p class="text-body text-text-secondary max-w-xl">
          Based in Düsseldorf. Available for project management roles, PMO consulting, and collaborations.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form — 3 cols -->
        <form
          action="https://formspree.io/f/mpqyanjn"
          method="POST"
          class="lg:col-span-3 space-y-5 reveal"
        >
          <div>
            <label for="name" class="block text-[14px] font-semibold text-text-primary mb-2">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Your name"
              class="w-full px-4 py-3 bg-white border border-border rounded-btn text-text-primary
                     placeholder:text-text-secondary/40 text-[15px]
                     focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none
                     transition-all duration-200"
            />
          </div>

          <div>
            <label for="email" class="block text-[14px] font-semibold text-text-primary mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="your@email.com"
              class="w-full px-4 py-3 bg-white border border-border rounded-btn text-text-primary
                     placeholder:text-text-secondary/40 text-[15px]
                     focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none
                     transition-all duration-200"
            />
          </div>

          <div>
            <label for="subject" class="block text-[14px] font-semibold text-text-primary mb-2">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="What's this about?"
              class="w-full px-4 py-3 bg-white border border-border rounded-btn text-text-primary
                     placeholder:text-text-secondary/40 text-[15px]
                     focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none
                     transition-all duration-200"
            />
          </div>

          <div>
            <label for="message" class="block text-[14px] font-semibold text-text-primary mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="Tell me about your project or opportunity..."
              class="w-full px-4 py-3 bg-white border border-border rounded-btn text-text-primary
                     placeholder:text-text-secondary/40 text-[15px] resize-vertical
                     focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none
                     transition-all duration-200"
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full sm:w-auto">
            Send Message
          </button>
        </form>

        <!-- Contact Info — 2 cols -->
        <div class="lg:col-span-2 reveal" style="animation-delay: 0.12s;">
          <div class="space-y-8">
            <div>
              <span class="text-meta text-text-secondary uppercase tracking-wider block mb-2">Email</span>
              <a href="mailto:emresendenel@gmail.com" class="inline-flex items-center gap-2 text-text-primary hover:text-accent transition-colors duration-200 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
                emresendenel@gmail.com
              </a>
            </div>

            <div>
              <span class="text-meta text-text-secondary uppercase tracking-wider block mb-2">Location</span>
              <p class="inline-flex items-center gap-2 text-text-primary font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="10" r="3"></circle>
                  <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"></path>
                </svg>
                Düsseldorf, Germany
              </p>
            </div>

            <div>
              <span class="text-meta text-text-secondary uppercase tracking-wider block mb-2">LinkedIn</span>
              <a href="https://www.linkedin.com/in/emresendenel" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-text-primary hover:text-accent transition-colors duration-200 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                  <rect x="2" y="9" width="4" height="12"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
                linkedin.com/in/emresendenel
              </a>
            </div>

            <div>
              <span class="text-meta text-text-secondary uppercase tracking-wider block mb-2">GitHub</span>
              <a href="https://github.com/emresendenel" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-text-primary hover:text-accent transition-colors duration-200 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                  <path d="M9 18c-4.51 2-5-2-7-2"></path>
                </svg>
                github.com/emresendenel
              </a>
            </div>

            <!-- Availability Card -->
            <div class="card p-5">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse shrink-0"></span>
                <span class="text-[14px] text-text-secondary">
                  Currently open to new opportunities in project management and consulting.
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
