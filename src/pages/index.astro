---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import ProjectCard from '../components/ProjectCard.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Emre Sendenel",
  "jobTitle": "Project Manager",
  "url": "https://emresendenel.com",
  "email": "emresendenel@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Düsseldorf",
    "addressCountry": "DE"
  },
  "sameAs": [
    "https://www.linkedin.com/in/emresendenel"
  ]
};

const timelineEntries = [
  {
    role: 'Projektleiter',
    company: 'CONET Services GmbH',
    period: 'Apr 2022 – Present',
    description: 'Leading complex IT projects in public sector and enterprise environments with cross-functional teams.',
    isCurrent: true,
  },
  {
    role: 'PMO / Project Management',
    company: 'intention.ist',
    period: 'Jun 2022 – Dec 2024',
    description: 'Established PMO processes and managed project portfolios for digital transformation initiatives.',
  },
  {
    role: 'Projektleiter',
    company: 'Public Sector',
    period: 'May 2023 – Apr 2024',
    description: 'Managed stakeholder-intensive public sector digitalization project with Agile delivery.',
  },
  {
    role: 'Product Owner / Project Manager',
    company: 'Doğuş Automotive',
    period: 'Feb 2010 – Nov 2017',
    description: 'Led digital product development and Agile adoption across automotive distribution operations.',
  },
];
---

<BaseLayout
  title="Emre Sendenel | Project Manager · PMP Certified"
  description="Emre Sendenel is a PMP-certified Project Manager based in Düsseldorf, Germany. 15+ years delivering complex projects across technology, automotive, and public sector."
  jsonLd={jsonLd}
>
  <!-- ==================== HERO ==================== -->
  <section
    id="hero"
    class="section-padding min-h-[80vh] lg:min-h-screen flex items-center"
  >
    <div class="container-content w-full">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Left Content -->
        <div class="flex-1 lg:max-w-[60%] animate-fade-up">
          <h1 class="font-display text-[40px] md:text-[52px] lg:text-hero font-bold text-text-primary mb-4 tracking-tight">
            Project Manager.
          </h1>
          <p class="text-[17px] md:text-[19px] font-body text-text-secondary mb-2 font-medium tracking-wide">
            PMP Certified · Düsseldorf, Germany
          </p>
          <p class="text-body text-text-secondary max-w-[520px] mb-8 leading-relaxed">
            Delivering complex projects across technology, automotive, and public sector. 15+ years turning strategy into execution.
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4 mb-8">
            <a href="/projects" class="btn-primary">View Projects</a>
            <a href="/contact" class="btn-secondary">Get in Touch</a>
          </div>

          <!-- Social Links -->
          <div class="flex items-center gap-4">
            <a
              href="https://www.linkedin.com/in/emresendenel"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary hover:text-accent transition-colors"
              aria-label="LinkedIn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
            <a
              href="mailto:emresendenel@gmail.com"
              class="text-text-secondary hover:text-accent transition-colors"
              aria-label="Email"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Right — Photo -->
        <div class="shrink-0 animate-fade-up" style="animation-delay: 0.2s;">
          <img
            src="/images/hero-photo.png"
            alt="Emre Sendenel — Project Manager"
            loading="eager"
            width="280"
            height="280"
            class="w-[220px] h-[220px] md:w-[280px] md:h-[280px] rounded-full object-cover border-2 border-border shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== ABOUT ==================== -->
  <section id="about" class="section-padding section-spacing bg-surface border-y border-border">
    <div class="container-content">
      <div class="reveal">
        <h2 class="font-display text-h2 text-text-primary mb-12">About</h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
          <!-- Left — Bio -->
          <div>
            <p class="text-body text-text-secondary leading-relaxed">
              I'm a certified Project Manager (PMP) with a background in Industrial Engineering and Marketing Management. I've led cross-functional teams at CONET Services, Doğuş Automotive, and in Germany's public sector — managing budgets, Agile workflows, and stakeholder complexity across industries.
            </p>
          </div>

          <!-- Right — Fast Facts -->
          <div class="space-y-4">
            {[
              { label: 'Certification', value: 'PMP (PMI)' },
              { label: 'Background', value: 'Industrial Engineering · Marketing Management' },
              { label: 'Location', value: 'Düsseldorf, Germany' },
              { label: 'Languages', value: 'Turkish · English · German' },
              { label: 'Tools', value: 'Jira · MS Project · Azure DevOps · MS Office' },
            ].map(({ label, value }) => (
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 py-3 border-b border-border last:border-b-0">
                <span class="text-meta text-text-secondary font-medium uppercase tracking-wider shrink-0 sm:w-32">
                  {label}
                </span>
                <span class="text-[15px] text-text-primary font-body">
                  {value}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== EXPERIENCE ==================== -->
  <section id="experience" class="section-padding section-spacing">
    <div class="container-content">
      <div class="reveal">
        <h2 class="font-display text-h2 text-text-primary mb-12">Experience</h2>
        <div class="max-w-2xl">
          <Timeline entries={timelineEntries} />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PROJECTS TEASER ==================== -->
  <section id="projects" class="section-padding section-spacing bg-surface border-y border-border">
    <div class="container-content">
      <div class="reveal">
        <h2 class="font-display text-h2 text-text-primary mb-12">Selected Projects</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <ProjectCard
            title="RTM — Road To Marathon"
            description="A marathon training companion app built web-first. Structured training plans, HealthKit integration, and post-run analytics."
            tags={['iOS App', 'Running', 'Product Management']}
            status="In Development"
            gradient="from-blue-50 to-indigo-50"
          />
        </div>

        <div class="mt-8 text-center lg:text-left">
          <a
            href="/projects"
            class="inline-flex items-center gap-2 text-accent hover:text-accent-hover transition-colors font-body font-medium text-[15px] group"
          >
            View All Projects
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CONTACT CTA ==================== -->
  <section id="contact-cta" class="section-padding section-spacing">
    <div class="container-content">
      <div class="reveal text-center max-w-xl mx-auto">
        <h2 class="font-display text-h2 text-text-primary mb-4">Let's Work Together</h2>
        <p class="text-body text-text-secondary mb-8">
          Open to project management roles, consulting, and collaborations.
        </p>
        <a href="/contact" class="btn-primary">Send a Message</a>
      </div>
    </div>
  </section>
</BaseLayout>
