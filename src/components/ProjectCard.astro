---
interface Props {
  title: string;
  description: string;
  tags: string[];
  role?: string;
  period?: string;
  status?: string;
  statusType?: 'current' | 'completed' | 'dev';
  logo?: string;
  logoAlt?: string;
  logoStyle?: 'default' | 'cover' | 'logo-left';
}

const {
  title,
  description,
  tags,
  role,
  period,
  status,
  statusType = 'completed',
  logo,
  logoAlt = '',
  logoStyle = 'default',
} = Astro.props;

const statusClass = statusType === 'current' ? 'status-current'
  : statusType === 'dev' ? 'status-dev'
  : 'status-completed';
---

<div class="card group cursor-default">
  <!-- Logo / Image -->
  {logo ? (
    logoStyle === 'cover' ? (
      <div class="-mx-6 -mt-6 mb-5 h-[160px] overflow-hidden rounded-t-card">
        <img
          src={logo}
          alt={logoAlt}
          class="w-full h-full object-cover"
          loading="lazy"
          width="400"
          height="160"
        />
      </div>
    ) : logoStyle === 'logo-left' ? (
      <div class="mb-5 flex items-center justify-start h-[40px]">
        <img
          src={logo}
          alt={logoAlt}
          class="max-w-[120px] max-h-[40px] object-contain"
          loading="lazy"
          width="120"
          height="40"
        />
      </div>
    ) : (
      <div class="w-full h-36 rounded-stats mb-5 bg-gray-50 flex items-center justify-center overflow-hidden">
        <img
          src={logo}
          alt={logoAlt}
          class="max-w-[70%] max-h-[80%] object-contain"
          loading="lazy"
          width="200"
          height="100"
        />
      </div>
    )
  ) : (
    <div class="w-full h-36 rounded-stats mb-5 card-gradient flex items-center justify-center">
      <span class="text-accent/30 text-[28px] font-bold select-none">
        {title.split(' ').map(w => w[0]).join('').slice(0, 3)}
      </span>
    </div>
  )}

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.map((tag) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>

  <!-- Title -->
  <h3 class="text-h3 font-semibold text-text-primary mb-1">{title}</h3>

  <!-- Role & Period -->
  {(role || period) && (
    <div class="mb-3 text-[14px] font-medium text-text-secondary flex flex-wrap gap-x-2 items-center">
      {role && <span class="text-accent font-semibold">{role}</span>}
      {role && period && <span class="text-border">·</span>}
      {period && <span>{period}</span>}
    </div>
  )}

  <!-- Description -->
  <p class="text-[15px] text-text-secondary leading-relaxed mb-4">{description}</p>

  <!-- Status -->
  {status && (
    <div class="flex items-center">
      <span class={statusClass}>{status}</span>
    </div>
  )}
</div>
