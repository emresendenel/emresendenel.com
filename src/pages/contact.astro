---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Emre Sendenel"
  description="Get in touch with Emre Sendenel — available for project management roles, PMO consulting, and collaborations. Based in Düsseldorf, Germany."
>
  <section class="section-padding section-spacing">
    <div class="container-content">
      <!-- Header -->
      <div class="mb-12 animate-fade-up">
        <h1 class="font-display text-[36px] md:text-hero font-bold text-text-primary mb-4">
          Get in Touch
        </h1>
        <p class="text-body text-text-secondary max-w-xl">
          Based in Düsseldorf. Available for project management roles, PMO consulting, and collaborations.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 reveal">
        <!-- Left — Contact Form -->
        <div>
          <form
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            class="space-y-6"
            id="contact-form"
          >
            <!-- Name -->
            <div>
              <label for="name" class="block text-[15px] font-medium text-text-primary mb-2 font-body">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your name"
                class="w-full px-4 py-3 bg-surface border border-border rounded-lg font-body text-body text-text-primary placeholder:text-text-secondary/50
                       focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-[15px] font-medium text-text-primary mb-2 font-body">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="your@email.com"
                class="w-full px-4 py-3 bg-surface border border-border rounded-lg font-body text-body text-text-primary placeholder:text-text-secondary/50
                       focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all"
              />
            </div>

            <!-- Subject -->
            <div>
              <label for="subject" class="block text-[15px] font-medium text-text-primary mb-2 font-body">
                Subject
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                placeholder="What's this about?"
                class="w-full px-4 py-3 bg-surface border border-border rounded-lg font-body text-body text-text-primary placeholder:text-text-secondary/50
                       focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-[15px] font-medium text-text-primary mb-2 font-body">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell me about your project or opportunity..."
                class="w-full px-4 py-3 bg-surface border border-border rounded-lg font-body text-body text-text-primary placeholder:text-text-secondary/50
                       focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all resize-y"
              ></textarea>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-primary w-full sm:w-auto" id="submit-btn">
              Send Message
            </button>
          </form>
        </div>

        <!-- Right — Contact Info -->
        <div class="lg:pl-8">
          <div class="space-y-8">
            <!-- Email -->
            <div>
              <h3 class="text-meta text-text-secondary font-medium uppercase tracking-wider mb-2">
                Email
              </h3>
              <a
                href="mailto:emresendenel@gmail.com"
                class="text-body text-text-primary hover:text-accent transition-colors font-body inline-flex items-center gap-2"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary">
                  <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
                emresendenel@gmail.com
              </a>
            </div>

            <!-- Location -->
            <div>
              <h3 class="text-meta text-text-secondary font-medium uppercase tracking-wider mb-2">
                Location
              </h3>
              <p class="text-body text-text-primary font-body inline-flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                Düsseldorf, Germany
              </p>
            </div>

            <!-- LinkedIn -->
            <div>
              <h3 class="text-meta text-text-secondary font-medium uppercase tracking-wider mb-2">
                LinkedIn
              </h3>
              <a
                href="https://www.linkedin.com/in/emresendenel"
                target="_blank"
                rel="noopener noreferrer"
                class="text-body text-text-primary hover:text-accent transition-colors font-body inline-flex items-center gap-2"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                  <rect x="2" y="9" width="4" height="12"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
                linkedin.com/in/emresendenel
              </a>
            </div>

            <!-- Availability note -->
            <div class="mt-8 p-6 bg-tag/50 rounded-xl border border-border">
              <p class="text-[15px] text-text-secondary leading-relaxed font-body">
                <span class="inline-block w-2 h-2 rounded-full bg-green-500 mr-2 animate-pulse"></span>
                Currently open to new opportunities in project management and consulting.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
