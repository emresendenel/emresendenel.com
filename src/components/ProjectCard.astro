---
interface Props {
  title: string;
  description: string;
  tags: string[];
  role?: string;
  period?: string;
  status?: string;
  statusType?: 'current' | 'completed' | 'dev';
  logo?: string;
  logoAlt?: string;
}

const {
  title,
  description,
  tags,
  role,
  period,
  status,
  statusType = 'completed',
  logo,
  logoAlt = '',
} = Astro.props;

const statusClass = statusType === 'current' ? 'status-current'
  : statusType === 'dev' ? 'status-dev'
  : 'status-completed';
---

<div class="card group cursor-default">
  <!-- Logo / Image -->
  {logo ? (
    <div class="-mx-6 -mt-6 mb-5 h-[180px] bg-[#F8F7FF] rounded-t-card overflow-hidden flex items-center justify-center">
      <img
        src={logo}
        alt={logoAlt}
        class="max-w-[60%] max-h-[100px] object-contain"
        loading="lazy"
        width="200"
        height="100"
      />
    </div>
  ) : (
    <div class="-mx-6 -mt-6 mb-5 h-[180px] card-gradient rounded-t-card overflow-hidden flex items-center justify-center">
      <span class="text-accent/30 text-[28px] font-bold select-none">
        {title.split(' ').map(w => w[0]).join('').slice(0, 3)}
      </span>
    </div>
  )}

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.map((tag) => (
      <span class="tag-chip">{tag}</span>
    ))}
  </div>

  <!-- Title -->
  <h3 class="text-h3 font-semibold text-text-primary mb-1">{title}</h3>

  <!-- Role & Period -->
  {(role || period) && (
    <div class="mb-3 text-[14px] font-medium text-text-secondary flex flex-wrap gap-x-2 items-center">
      {role && <span class="text-accent font-semibold">{role}</span>}
      {role && period && <span class="text-border">·</span>}
      {period && <span>{period}</span>}
    </div>
  )}

  <!-- Description -->
  <p class="text-[15px] text-text-secondary leading-relaxed mb-4">{description}</p>

  <!-- Status -->
  {status && (
    <div class="flex items-center">
      <span class={statusClass}>{status}</span>
    </div>
  )}
</div>
